# PostgreSQL Database URL
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# For Render.com (automatically provided by Render):
# DATABASE_URL=<provided by Render>

# Node environment
NODE_ENV=development

# Admin secret for broadcast messages (generate a random string)
# Used by AdminBroadcast.js to authenticate admin messages
ADMIN_SECRET=your-secret-here-change-this
